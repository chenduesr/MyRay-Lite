                                                            </StackPanel>
                                                            <Button Grid.Column="5" Background="Transparent" BorderBrush="Transparent" Click="ViewNodeDetails_Click" Tag="{Binding Id}" ToolTip="查看节点详情">
                                                                <TextBlock Style="{StaticResource IconText}" Text="&#xE76C;" Foreground="#B7C2D0" FontSize="18" />
                                                            </Button>
                                                            <Border Grid.Column="1" Grid.ColumnSpan="5" Height="1" Background="{StaticResource LineBrush}" VerticalAlignment="Bottom" />
                                                        </Grid>
                                                    </Border>

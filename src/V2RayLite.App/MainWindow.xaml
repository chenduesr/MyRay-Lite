                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                        <Border Background="#EEF6FF" BorderBrush="#CFE4FF" BorderThickness="1" CornerRadius="10" Padding="8,2" Margin="0,0,6,0"><TextBlock Text="{Binding Protocol}" Style="{StaticResource BadgeText}" Foreground="{StaticResource BlueBrush}" /></Border>
                                                                        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="8,2"><TextBlock Text="{Binding Network}" Style="{StaticResource BadgeText}" Foreground="{StaticResource SubtleTextBrush}" /></Border>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Button>
                                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="{Binding DisplayFailureReason}">
                                                                <Border Background="{Binding Status, Converter={x:Static local:NodeStatusSoftBrushConverter.Instance}}" BorderBrush="#D8E2EF" BorderThickness="1" CornerRadius="12" Padding="10,3">
                                                                    <TextBlock Text="{Binding DisplayDelay}" FontSize="16" Foreground="{Binding Status, Converter={x:Static local:NodeDelayBrushConverter.Instance}}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                                </Border>
                                                                <TextBlock Text="{Binding DisplayTestType}" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center" ToolTip="{Binding DisplayFailureReason}">
                                                                <Border Background="{Binding Status, Converter={x:Static local:NodeStatusSoftBrushConverter.Instance}}" BorderBrush="#D8E2EF" BorderThickness="1" CornerRadius="12" Padding="10,3" Margin="0,0,0,5">

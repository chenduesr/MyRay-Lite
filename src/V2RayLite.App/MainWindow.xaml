                                            <TextBlock Text="阻止 IP / 黑名单" FontSize="15" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,8" />
                                            <TextBox x:Name="BlockIpsTextBox" Style="{StaticResource MultiLineTextBox}" TextChanged="AdvancedTextBox_TextChanged" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>

                                        <RadioButton x:Name="DirectModeRadio" Content="直连模式" GroupName="ProxyMode" Checked="ProxyMode_Checked" Tag="Direct" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,0,0,18" Visibility="{Binding SettingsSection, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Basic}">

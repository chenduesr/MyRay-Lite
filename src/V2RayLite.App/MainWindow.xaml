                                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,18,18">
                                    <StackPanel>
                                        <Button Content="基础" Tag="Basic" Style="{StaticResource OutlineButton}" Height="42" Margin="0,0,0,8" Click="SettingsSection_Click" />
                                        <Button Content="代理" Tag="Proxy" Style="{StaticResource OutlineButton}" Height="42" Margin="0,0,0,8" Click="SettingsSection_Click" />

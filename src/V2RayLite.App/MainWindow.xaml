                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding LastUpdateText}" FontSize="18" Foreground="{StaticResource BlueBrush}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Background="{StaticResource LineBrush}" Height="1" VerticalAlignment="Bottom" />

                                    <TextBlock Grid.Row="2" Style="{StaticResource IconText}" Text="&#xE9D9;" Foreground="{StaticResource BlueBrush}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="协议核心：" FontSize="19" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Xray" FontSize="19" Foreground="{StaticResource BlueBrush}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    <Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Background="{StaticResource LineBrush}" Height="1" VerticalAlignment="Bottom" />


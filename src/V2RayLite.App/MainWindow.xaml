                                    <TextBox x:Name="DelayTestUrlTextBox" Grid.Row="3" Grid.Column="1" TextChanged="DelayTestUrlTextBox_TextChanged" />
                                    <TextBlock Grid.Row="4" Text="测速模式:" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <ComboBox x:Name="DelayTestModeComboBox" Grid.Row="4" Grid.Column="1" Height="46" FontSize="16" SelectionChanged="DelayTestModeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="TCP 延迟：最快，接近 v2rayN 列表延迟" />
                                        <ComboBoxItem Content="HTTP 延迟：真实经过 Xray 代理访问测速 URL" />
                                        <ComboBoxItem Content="下载测速：真实经过 Xray 代理读取 1 MB 数据" />
                                    </ComboBox>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource Card}" Padding="24,20" Visibility="{Binding SettingsSection, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Update}">
                                <StackPanel>
                                    <TextBlock Text="更新" FontSize="21" FontWeight="Bold" Margin="0,0,0,6" />
                                    <TextBlock Text="管理 MyRay Lite 更新、Xray Core 版本和 geoip/geosite 数据。" FontSize="14" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,18" />
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="36" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="应用版本" FontSize="16" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding AppVersionText}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Text="当前核心" FontSize="16" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding XrayCoreVersionText}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource BlueBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="2" Text="geo 数据" FontSize="16" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GeoDataStatusText}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Text="{Binding XrayLatestVersionText, StringFormat=最新核心：{0}}" FontSize="14" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,14" />
                                    <UniformGrid Columns="4" Rows="1">
                                        <Button Content="检查应用" Style="{StaticResource OutlineButton}" Height="42" Margin="0,0,6,0" Click="CheckUpdate_Click" />
                                        <Button Content="检查核心" Style="{StaticResource OutlineButton}" Height="42" Margin="3,0" Click="CheckXrayCore_Click" />
                                        <Button Content="更新核心" Style="{StaticResource OutlineButton}" Height="42" Margin="3,0" Click="UpdateXrayCore_Click" />
                                        <Button Content="更新 geo" Style="{StaticResource PrimaryButton}" Height="42" Margin="6,0,0,0" Click="UpdateGeoData_Click" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                            </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageVisibilityConverter}, ConverterParameter=Logs}">
                        <Grid Width="880" HorizontalAlignment="Center" Margin="0,32,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="日志诊断" Style="{StaticResource PageTitleText}" Margin="0,10,0,20" />
                            <Grid Grid.Row="1" Margin="0,0,0,18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="显示应用日志、Xray 启动日志和测速诊断。Xray 启动失败时优先看这里。"
                                           Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,12" />
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="全部日志" Tag="全部" Style="{StaticResource OutlineButton}" Height="36" Width="96" Padding="0" FontSize="14" Margin="0,0,8,0" Click="LogSource_Click" />
                                    <Button Content="应用日志" Tag="应用" Style="{StaticResource OutlineButton}" Height="36" Width="96" Padding="0" FontSize="14" Margin="0,0,8,0" Click="LogSource_Click" />
                                    <Button Content="Xray 日志" Tag="Xray" Style="{StaticResource OutlineButton}" Height="36" Width="96" Padding="0" FontSize="14" Click="LogSource_Click" />
                                </StackPanel>
                                <Grid Grid.Row="2" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="126" />
                                        <ColumnDefinition Width="124" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <TextBox x:Name="LogSearchTextBox" Height="44" FontSize="15" Padding="46,0,12,0" TextChanged="LogSearchTextBox_TextChanged" />
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE721;" Foreground="#718096" HorizontalAlignment="Left" Width="38" Margin="8,0,0,0" FontSize="18" />
                                        <TextBlock Text="搜索日志" IsHitTestVisible="False" Margin="46,0,0,0" VerticalAlignment="Center" Foreground="#9AA6B2" FontSize="15" Visibility="{Binding IsLogSearchEmpty, Converter={StaticResource BoolVisibilityConverter}}" />
                                    </Grid>
                                    <ComboBox x:Name="LogLevelComboBox" Grid.Column="1" Height="44" Margin="10,0,0,0" FontSize="15" SelectedIndex="0" SelectionChanged="LogLevelComboBox_SelectionChanged">
                                        <ComboBoxItem Content="全部" />
                                        <ComboBoxItem Content="ERROR" />
                                        <ComboBoxItem Content="WARN" />
                                        <ComboBoxItem Content="INFO" />
                                        <ComboBoxItem Content="XRAY" />
                                    </ComboBox>
                                    <CheckBox x:Name="LogAutoScrollCheckBox" Grid.Column="2" Content="自动滚动" IsChecked="True" FontSize="15" Margin="12,0,0,0" Click="LogAutoScroll_Click" />
                                </Grid>
                                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource OutlineButton}" Width="96" Height="44" Margin="0,0,10,0" Padding="0" HorizontalContentAlignment="Center" Click="RefreshLogs_Click" Content="刷新" />
                                    <Button Style="{StaticResource OutlineButton}" Width="96" Height="44" Margin="0,0,10,0" Padding="0" HorizontalContentAlignment="Center" Click="RunDiagnostics_Click" Content="诊断" />
                                    <Button Style="{StaticResource OutlineButton}" Width="108" Height="44" Margin="0,0,10,0" Padding="0" HorizontalContentAlignment="Center" Click="CreateDiagnosticPackage_Click" Content="诊断包" />
                                    <Button Style="{StaticResource OutlineButton}" Width="96" Height="44" Margin="0,0,10,0" Padding="0" HorizontalContentAlignment="Center" Click="CopyLogs_Click" Content="复制" />
                                    <Button Style="{StaticResource OutlineButton}" Width="108" Height="44" Margin="0,0,10,0" Padding="0" HorizontalContentAlignment="Center" Click="CopyErrorLogs_Click" Content="复制错误" />
                                    <Button Style="{StaticResource OutlineButton}" Width="96" Height="44" Margin="0,0,10,0" Padding="0" HorizontalContentAlignment="Center" Click="ClearLogs_Click" Content="清空" />
                                    <Button Style="{StaticResource PrimaryButton}" Width="120" Height="44" Padding="0" HorizontalContentAlignment="Center" Click="OpenLogFolder_Click" Content="打开目录" />
                                </StackPanel>
                            </Grid>
                            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" MinHeight="430">
                                <Grid>
                                    <TextBlock Text="{Binding LogLineCountText}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,18,0" Foreground="{StaticResource SubtleTextBrush}" FontSize="13" FontWeight="SemiBold" Panel.ZIndex="2" />
                                    <ScrollViewer x:Name="LogsScrollViewer" VerticalScrollBarVisibility="Auto" Padding="18,42,18,18">
                                        <ItemsControl ItemsSource="{Binding LogLines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource LogListRow}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="58" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Background="{Binding BadgeBackground}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding Level}" Style="{StaticResource BadgeText}" Foreground="{Binding BadgeForeground}" />
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding Text}" FontFamily="Consolas" FontSize="13" Foreground="{Binding Foreground}" TextWrapping="Wrap" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <StackPanel Visibility="{Binding HasLogs, Converter={StaticResource InverseBoolVisibilityConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource IconText}" Text="&#xE9D9;" Foreground="#B8C4D2" FontSize="42" HorizontalAlignment="Center" Margin="0,0,0,12" />
                                        <TextBlock Text="暂无匹配日志" Foreground="{StaticResource SubtleTextBrush}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        <TextBlock Text="可以切换来源、等级或清空搜索条件。" Foreground="{StaticResource SubtleTextBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <Border x:Name="NodeDetailPanel"
                        Visibility="{Binding IsNodeDetailOpen, Converter={StaticResource BoolVisibilityConverter}}"
                        Width="430"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Stretch"
                        Margin="0,86,18,24"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="22">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="NodeDetailTransform" />
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="6" Opacity="0.16" Color="#64748B" />
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="节点详情" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                            <Button Style="{StaticResource WindowButton}" HorizontalAlignment="Right" Click="CloseNodeDetails_Click" Content="×" />
                        </Grid>
                        <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedNodeDetail.Name}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedNodeDetail.DisplayFailureReason}" FontSize="14" Foreground="#F97316" TextWrapping="Wrap" Margin="0,8,0,12" />
                                <UniformGrid Columns="3" Rows="1" Margin="0,0,0,16">
                                    <Button Content="连接" Style="{StaticResource PrimaryButton}" Height="40" Margin="0,0,6,0" Padding="0" FontSize="15" Click="ConnectSelectedNode_Click" />
                                    <Button Content="测速" Style="{StaticResource OutlineButton}" Height="40" Margin="3,0" Padding="0" FontSize="15" Click="TestSelectedNode_Click" />
                                    <Button Content="复制名称" Style="{StaticResource OutlineButton}" Height="40" Margin="6,0,0,0" Padding="0" FontSize="15" Click="CopyNodeName_Click" />
                                </UniformGrid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="108" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="50" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="38" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="名称" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Column="1" Text="{Binding SelectedNodeDetail.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" />
                                    <TextBlock Grid.Row="1" Text="地址" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedNodeDetail.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" />
                                    <TextBlock Grid.Row="2" Text="端口" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedNodeDetail.Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" />
                                    <TextBlock Grid.Row="3" Text="传输" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectedNodeDetail.Network, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" />
                                    <TextBlock Grid.Row="4" Text="安全" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SelectedNodeDetail.Security, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" />
                                    <TextBlock Grid.Row="5" Text="SNI" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SelectedNodeDetail.Sni, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" />
                                    <TextBlock Grid.Row="6" Text="Host" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SelectedNodeDetail.Host, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" />
                                    <TextBlock Grid.Row="7" Text="Path" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SelectedNodeDetail.Path, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="40" FontSize="15" />
                                    <TextBlock Grid.Row="8" Text="协议" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedNodeDetail.Protocol}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="9" Text="延迟" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedNodeDetail.DisplayDelay}" Foreground="{StaticResource BlueBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="10" Text="测速" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding SelectedNodeDetail.DisplayTestType}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="11" Text="状态" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="11" Grid.Column="1" Text="{Binding SelectedNodeDetail.Status}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="12" Text="端点" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding SelectedNodeEndpointText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="13" Text="来源" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="13" Grid.Column="1" Text="{Binding SelectedNodeSubscriptionText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="14" Text="最近测速" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Row="14" Grid.Column="1" Text="{Binding SelectedNodeLastTestText}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </Grid>

                                <Button Content="保存修改" Style="{StaticResource PrimaryButton}" Height="44" Margin="0,20,0,0" Click="SaveNodeDetails_Click" />
                                <Button Content="复制节点信息" Style="{StaticResource OutlineButton}" Height="44" Margin="0,10,0,0" Click="CopyNode_Click" Tag="{Binding SelectedNodeDetail.Id}" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.RowSpan="2"
                      Panel.ZIndex="200"
                      Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolVisibilityConverter}}"
                      Background="#660F172A">
                    <Border x:Name="DialogCard"
                            Width="460"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="26"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="DialogCardTransform" />
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="6" Opacity="0.18" Color="#0F172A" />
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="{Binding DialogTitle}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" />
                            <TextBlock Text="{Binding DialogMessage}" FontSize="15" Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap" Margin="0,14,0,22" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Content="{Binding DialogSecondaryText}" Visibility="{Binding HasDialogSecondary, Converter={StaticResource BoolVisibilityConverter}}" Style="{StaticResource OutlineButton}" Height="46" Margin="0,0,8,0" Click="DialogSecondary_Click" />
                                <Button Grid.Column="1" Content="{Binding DialogPrimaryText}" Style="{StaticResource PrimaryButton}" Height="46" Margin="8,0,0,0" Click="DialogPrimary_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="ToastCard"
                        Grid.RowSpan="2"
                        Panel.ZIndex="150"
                        Visibility="{Binding HasToast, Converter={StaticResource BoolVisibilityConverter}}"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,88,22,0">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ToastTransform" />
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.10" Color="#64748B" />
                    </Border.Effect>
                    <TextBlock Text="{Binding ToastMessage}" Foreground="{StaticResource SubtleTextBrush}" FontSize="14" TextWrapping="Wrap" MaxWidth="420" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
